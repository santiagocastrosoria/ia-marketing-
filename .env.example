# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Requerido para persistencia server-side (repository usa service role + ownership manual)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (future: AI-enhanced copy generation)
OPENAI_API_KEY=

# Meta Marketing API
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Ads mode: mock | read_only | draft_only | live_approval
# mock = simulación completa, sin APIs reales
# read_only = lectura Meta Marketing API (cuenta, campañas, insights) — sin escritura
# draft_only = (futuro) crear campañas reales solo en PAUSED/DRAFT
# live_approval = (futuro) activar solo con aprobación humana
ADS_MODE=mock
NEXT_PUBLIC_ADS_MODE=mock

# Demo user UUID (opcional). Debe ser un UUID válido para columnas user_id en Supabase.
DEMO_USER_ID=00000000-0000-0000-0000-000000000001

# Solo desarrollo: permite usar DEMO_USER_ID sin login (nunca en producción)
ENABLE_DEMO_USER=false
